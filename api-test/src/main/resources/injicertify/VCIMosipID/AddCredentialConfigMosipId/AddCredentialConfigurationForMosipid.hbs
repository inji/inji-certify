{
"vcTemplate": {
  "@context": [{{#each @context}}"{{context_value}}"{{#unless @last}},{{/unless}}{{/each}}],
  "issuer": "${_issuer}",
  "type": [{{#each type}}"{{type_value}}"{{#unless @last}},{{/unless}}{{/each}}],
  "issuanceDate": "${validFrom}",
  "expirationDate": "${validUntil}",

  "credentialSubject": {
    "id": "${_holderId}"

    {{#if fullName}},
    "fullName": [
      {{#each fullName}}
      {
        "value": "{{this.value}}",
        "language": "{{this.language}}"
      }{{#unless @last}},{{/unless}}
      {{/each}}
    ]
    {{/if}}

    {{#if gender}},
    "gender": [
      {{#each gender}}
      {
        "value": "{{this.value}}",
        "language": "{{this.language}}"
      }{{#unless @last}},{{/unless}}
      {{/each}}
    ]
    {{/if}}

    {{#if dateOfBirth}}, "dateOfBirth": "{{dateOfBirth}}"{{/if}}
    {{#if phone}}, "phone": "{{phone}}"{{/if}}
    {{#if email}}, "email": "{{email}}"{{/if}}

    {{#if province}},
    "province": [
      {{#each province}}
      {
        "value": "{{this.value}}",
        "language": "{{this.language}}"
      }{{#unless @last}},{{/unless}}
      {{/each}}
    ]
    {{/if}}

    {{#if region}},
    "region": [
      {{#each region}}
      {
        "value": "{{this.value}}",
        "language": "{{this.language}}"
      }{{#unless @last}},{{/unless}}
      {{/each}}
    ]
    {{/if}}

    {{#if city}},
    "city": [
      {{#each city}}
      {
        "value": "{{this.value}}",
        "language": "{{this.language}}"
      }{{#unless @last}},{{/unless}}
      {{/each}}
    ]
    {{/if}}

    {{#if postalCode}}, "postalCode": "{{postalCode}}"{{/if}}
    {{#if UIN}}, "UIN": "{{UIN}}"{{/if}}
    {{#if VID}}, "VID": "{{VID}}"{{/if}}

    {{#if face}}, "face": "{{face}}"{{/if}}
    {{#if compressedFace}}, "compressedFace": "{{compressedFace}}"{{/if}}

    {{#if identityQRCode}},
    "claim169": {
      "identityQRCode": "{{identityQRCode}}"
    }
    {{/if}}
  }
},
"contextURLs": [
	      {{#each contextURLs}}
	            "{{contextURLs}}"
	          {{#unless @last}},{{/unless}}
	      	{{/each}}
        ],
	"credentialTypes": [
	      {{#each credentialTypes}}
	            "{{credentialTypes}}"
	          {{#unless @last}},{{/unless}}
	      	{{/each}}
        ], 
"credentialFormat": "{{credentialFormat}}",
"credentialConfigKeyId": "{{credentialConfigKeyId}}",
"didUrl": "{{didUrl}}",
"keyManagerAppId": "{{keyManagerAppId}}",
"keyManagerRefId": "{{keyManagerRefId}}",
"signatureAlgo": "{{signatureAlgo}}",
"signatureCryptoSuite": "{{signatureCryptoSuite}}",

"displayOrder": [{{#each displayOrder}}"{{displayOrder_values}}"{{#unless @last}},{{/unless}}{{/each}}],

"scope": "{{scope}}",

"qrSettings": [
  {{#each qrSettings}}
  {
    {{#each this}}
    "{{@key}}": "{{this}}"{{#unless @last}},{{/unless}}
    {{/each}}
  }{{#unless @last}},{{/unless}}
  {{/each}}
],

"qrSignatureAlgo": "{{qrSignatureAlgo}}",

"metaDataDisplay": [{
  "name": "{{display_name}}",
  "locale": "{{display_locale}}"
}],

"credentialSubjectDefinition": {
  {{#each credentialSubjectDefinition}}
  "{{field_name}}": {
    "display": [
      {{#each display}}
      {
        "name": "{{name}}",
        "locale": "{{locale}}"
      }{{#unless @last}},{{/unless}}
      {{/each}}
    ]
  }{{#unless @last}},{{/unless}}
  {{/each}}
}
}